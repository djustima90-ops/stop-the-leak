{
  "builds": [
    { "src": "app.py", "use": "@vercel/python", "config": { "maxLambdaSize": "50mb" } },
    { "src": "static/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)", "dest": "app.py" }
  ],
  "functions": {
    "app.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
